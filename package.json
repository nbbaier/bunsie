{
  "name": "bunsie-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3",
    "ultracite": "7.1.5"
  },
  "scripts": {
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsgo --noEmit",
    "build:cli": "bun run --filter=bunsie build",
    "build:example": "bun run --filter=example build"
  },
  "module": "index.ts",
  "type": "module"
}
